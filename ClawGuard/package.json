{
  "name": "clawguard",
  "version": "0.1.0",
  "private": true,
  "description": "Declarative capability enforcement framework for OpenClaw — OAuth-style, on-chain enforced permission middleware.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:core": "npm run test --workspace=packages/core",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
