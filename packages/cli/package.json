{
  "name": "@clawguard/cli",
  "version": "0.1.0",
  "private": true,
  "description": "ClawGuard CLI — skill submission, verification, and inspection",
  "main": "dist/index.js",
  "bin": {
    "clawguard": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node -r tsconfig-paths/register --transpile-only src/index.ts",
    "clean": "rimraf dist",
    "cli": "ts-node -r tsconfig-paths/register --transpile-only src/index.ts",
    "publish:skill": "ts-node -r tsconfig-paths/register --transpile-only src/index.ts publish",
    "verify:skill": "ts-node -r tsconfig-paths/register --transpile-only src/index.ts verify",
    "inspect": "ts-node -r tsconfig-paths/register --transpile-only src/index.ts inspect",
    "ens:bootstrap": "ts-node -r tsconfig-paths/register --transpile-only ../../packages/contracts/src/ENSRegistrar.ts bootstrap",
    "ens:register": "ts-node -r tsconfig-paths/register --transpile-only ../../packages/contracts/src/ENSRegistrar.ts register",
    "ens:resolve": "ts-node -r tsconfig-paths/register --transpile-only ../../packages/contracts/src/ENSRegistrar.ts resolve",
    "ens:revoke": "ts-node -r tsconfig-paths/register --transpile-only ../../packages/contracts/src/ENSRegistrar.ts revoke"
  },
  "dependencies": {
    "@0gfoundation/0g-ts-sdk": "^1.2.8",
    "@0glabs/0g-serving-broker": "^0.7.8",
    "@clawguard/core": "*",
    "@ensdomains/ensjs": "^4.2.2",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.0",
    "tsconfig-paths": "^4.2.0",
    "viem": "^2.48.7"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "rimraf": "^5.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  }
}
