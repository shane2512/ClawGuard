# ClawGuard Demo — Environment Variables
# Copy this file: cp .env.example .env
# Fill in real values before running any demo scene.
# All values are read from the PARENT project's .env automatically (see config.ts).
# You only need this file if running the demo folder standalone.

# ── 0G Chain (Galileo Testnet, chainId 16602) ──────────────────────────────
ZG_PRIVATE_KEY=             # Wallet private key (hex, no 0x prefix needed)
ZG_CHAIN_RPC=               # e.g. https://evmrpc-testnet.0g.ai
ZG_CHAIN_ID=16602

# ── 0G Storage ──────────────────────────────────────────────────────────────
ZG_INDEXER_RPC=             # e.g. https://indexer-storage-testnet-turbo.0g.ai
ZG_FLOW_CONTRACT=           # e.g. 0x22E03a6A89B950F1c82ec5e74F8eCa321a105296

# ── 0G Compute ──────────────────────────────────────────────────────────────
ZG_COMPUTE_RPC=             # Usually same as ZG_CHAIN_RPC

# ── SkillRegistry (deployed on 0G Galileo) ──────────────────────────────────
REGISTRY_ADDRESS=           # e.g. 0x2205AC38725F42d9da0ffaDD94166B5E5b83010A

# ── ENS (Sepolia testnet) ────────────────────────────────────────────────────
ETH_SEPOLIA_RPC=            # e.g. https://ethereum-sepolia-rpc.publicnode.com
ENS_SKILL_NAME=defi-reader.skills.clawhub.eth

# ── Demo Config ──────────────────────────────────────────────────────────────
AGENT_ID=clawguard-demo-agent
NODE_ENV=development
